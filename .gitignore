vite.config.ts.timestamp-*

# ---- Agent / AI Tool Internals (NOT for repo) ----
.figma/
.impeccable/
.agents/
skills-lock.json
CLAUDE.md

# ---- Lock files (keep only one — npm) ----
pnpm-lock.yaml

# ---- Misc ----
*.local
