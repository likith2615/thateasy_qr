.env
.env.local
.env.*.local
.env.production

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---- Editor / OS ----
.DS_Store
Thumbs.db
*.suo
*.user
.idea/
.vscode/settings.json
*.swp
*.swo

# ---- TypeScript ----
*.tsbuildinfo

